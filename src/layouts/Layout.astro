---
import Logo from '../components/Logo.astro';

interface Props {
  title: string;
  activeNav?: 'services' | 'about' | 'contact';
  description?: string;
  ogImage?: string;
}

const {
  title,
  activeNav,
  description = 'システム開発・DX支援、AI導入・研修、Web制作の3領域で、vectonは業務の複雑さに向き合い、シンプルな技術でビジネス課題を解決します。',
  ogImage = '/og-image.png',
} = Astro.props;

const siteUrl = Astro.site ?? new URL('https://vecton.jp');
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
const ogImageUrl = new URL(ogImage, siteUrl).href;
---
<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="canonical" href={canonicalUrl}>

  <meta property="og:type" content="website">
  <meta property="og:url" content={canonicalUrl}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content={ogImageUrl}>
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:locale" content="ja_JP">
  <meta property="og:site_name" content="vecton">

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={ogImageUrl}>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&family=Zen+Maru+Gothic+New:wght@400;500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles/shared.css">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">
  <meta name="theme-color" content="#fafaf8">
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: '株式会社Vecton',
    url: siteUrl.href,
    logo: new URL('/logo.svg', siteUrl).href,
    address: {
      '@type': 'PostalAddress',
      addressRegion: '岩手県',
      addressLocality: '盛岡市',
      streetAddress: '津志田町二丁目8-10',
      addressCountry: 'JP',
    },
    founder: { '@type': 'Person', name: '角舘 大' },
    foundingDate: '2026-08-01',
  })} />
  <slot name="head" />
</head>
<body>
<a href="#main" class="skip-link">本文へスキップ</a>

<nav class="nav" id="nav">
  <a href="/" class="nav-logo">
    <Logo />
  </a>
  <button class="nav-toggle" id="navToggle" aria-label="メニュー" aria-expanded="false" aria-controls="navLinks">
    <span class="nav-toggle-bar"></span>
    <span class="nav-toggle-bar"></span>
    <span class="nav-toggle-bar"></span>
  </button>
  <ul class="nav-links" id="navLinks">
    <li><a href="/services" class={activeNav === 'services' ? 'active' : ''}>事業内容</a></li>
    <li><a href="/about" class={activeNav === 'about' ? 'active' : ''}>会社概要</a></li>
    <li><a href="/contact" class={`nav-cta${activeNav === 'contact' ? ' active' : ''}`}>お問い合わせ</a></li>
  </ul>
</nav>

<main id="main">
<slot />
</main>

<footer>
  <div class="footer-logo">
    <Logo class="footer-wordmark-logo" />
  </div>
  <ul class="footer-links">
    <li><a href="/services">事業内容</a></li>
    <li><a href="/about">会社概要</a></li>
    <li><a href="/contact">お問い合わせ</a></li>
    <li><a href="/privacy">プライバシーポリシー</a></li>
  </ul>
  <p class="footer-copy">© 2026 vecton Inc. All rights reserved.</p>
</footer>

<script>
const nav = document.getElementById('nav');
window.addEventListener('scroll', () => {
  nav?.classList.toggle('scrolled', window.scrollY > 20);
}, { passive: true });

const toggle = document.getElementById('navToggle');
const navLinks = document.getElementById('navLinks');
toggle?.addEventListener('click', () => {
  const open = navLinks?.classList.toggle('open');
  toggle.classList.toggle('open', !!open);
  toggle.setAttribute('aria-expanded', String(!!open));
});
navLinks?.querySelectorAll('a').forEach(a => {
  a.addEventListener('click', () => {
    navLinks.classList.remove('open');
    toggle?.classList.remove('open');
    toggle?.setAttribute('aria-expanded', 'false');
  });
});
</script>

</body>
</html>
