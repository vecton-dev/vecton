---
interface Props {
  title: string;
  activeNav?: 'services' | 'about' | 'members' | 'contact';
}
const { title, activeNav } = Astro.props;
---
<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <link rel="stylesheet" href="/styles/shared.css">
  <slot name="head" />
</head>
<body>

<nav class="nav" id="nav">
  <a href="/" class="nav-logo">
    <svg class="nav-logo-svg" viewBox="0 0 210 68" fill="none" xmlns="http://www.w3.org/2000/svg" style="height:34px;width:auto;">
      <circle cx="34" cy="34" r="23"
        stroke="#1a1a2e" stroke-width="2" stroke-linecap="round"
        stroke-dasharray="115 29" transform="rotate(-30 34 34)"/>
      <text x="72" y="43"
        font-family="DM Sans, sans-serif"
        font-size="23" font-weight="300"
        letter-spacing="7" fill="#1a1a2e">vecton</text>
    </svg>
  </a>
  <ul class="nav-links">
    <li><a href="/services" class={activeNav === 'services' ? 'active' : ''}>事業内容</a></li>
    <li><a href="/about" class={activeNav === 'about' ? 'active' : ''}>会社概要</a></li>
    <li><a href="/members" class={activeNav === 'members' ? 'active' : ''}>メンバー</a></li>
    <li><a href="/contact" class={`nav-cta${activeNav === 'contact' ? ' active' : ''}`}>お問い合わせ</a></li>
  </ul>
</nav>

<slot />

<footer>
  <div class="footer-logo">
    <svg viewBox="0 0 210 68" fill="none" style="height:26px;width:auto;">
      <circle cx="34" cy="34" r="23"
        stroke="rgba(255,255,255,0.6)" stroke-width="2" stroke-linecap="round"
        stroke-dasharray="115 29" transform="rotate(-30 34 34)"/>
      <text x="72" y="43"
        font-family="DM Sans, sans-serif"
        font-size="23" font-weight="300"
        letter-spacing="7" fill="rgba(255,255,255,0.6)">vecton</text>
    </svg>
  </div>
  <ul class="footer-links">
    <li><a href="/services">事業内容</a></li>
    <li><a href="/about">会社概要</a></li>
    <li><a href="/members">メンバー</a></li>
    <li><a href="/contact">お問い合わせ</a></li>
  </ul>
  <p class="footer-copy">© 2025 vecton Inc. All rights reserved.</p>
</footer>

<script>
const nav = document.getElementById('nav');
window.addEventListener('scroll', () => {
  nav?.classList.toggle('scrolled', window.scrollY > 20);
}, { passive: true });
</script>

</body>
</html>
