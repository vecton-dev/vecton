---
interface Props {
  title: string;
  activeNav?: 'services' | 'about' | 'members' | 'contact';
}
const { title, activeNav } = Astro.props;
---
<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <link rel="stylesheet" href="/styles/shared.css">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <slot name="head" />
</head>
<body>

<nav class="nav" id="nav">
  <a href="/" class="nav-logo">
    <span class="wordmark">vecton</span>
  </a>
  <button class="nav-toggle" id="navToggle" aria-label="メニューを開く">
    <span class="nav-toggle-bar"></span>
    <span class="nav-toggle-bar"></span>
    <span class="nav-toggle-bar"></span>
  </button>
  <ul class="nav-links" id="navLinks">
    <li><a href="/services" class={activeNav === 'services' ? 'active' : ''}>事業内容</a></li>
    <li><a href="/about" class={activeNav === 'about' ? 'active' : ''}>会社概要</a></li>
    <li><a href="/members" class={activeNav === 'members' ? 'active' : ''}>メンバー</a></li>
    <li><a href="/contact" class={`nav-cta${activeNav === 'contact' ? ' active' : ''}`}>お問い合わせ</a></li>
  </ul>
</nav>

<slot />

<footer>
  <div class="footer-logo">
    <span class="wordmark">vecton</span>
  </div>
  <ul class="footer-links">
    <li><a href="/services">事業内容</a></li>
    <li><a href="/about">会社概要</a></li>
    <li><a href="/members">メンバー</a></li>
    <li><a href="/contact">お問い合わせ</a></li>
  </ul>
  <p class="footer-copy">© 2025 vecton Inc. All rights reserved.</p>
</footer>

<script>
const nav = document.getElementById('nav');
window.addEventListener('scroll', () => {
  nav?.classList.toggle('scrolled', window.scrollY > 20);
}, { passive: true });

const toggle = document.getElementById('navToggle');
const navLinks = document.getElementById('navLinks');
toggle?.addEventListener('click', () => {
  const open = navLinks?.classList.toggle('open');
  toggle.classList.toggle('open', open);
  toggle.setAttribute('aria-label', open ? 'メニューを閉じる' : 'メニューを開く');
});
navLinks?.querySelectorAll('a').forEach(a => {
  a.addEventListener('click', () => {
    navLinks.classList.remove('open');
    toggle?.classList.remove('open');
  });
});
</script>

</body>
</html>
