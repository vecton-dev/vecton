---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
---
<Layout
  title="vecton — 複雑をシンプルに"
  description="システム開発・DX支援、AI導入・研修、Web制作の3領域でお客様のビジネス課題を解決します。"
>
  <slot name="head" slot="head">
    <style>
    .hero {
      position: relative;
      height: 100svh; min-height: 600px;
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      overflow: hidden;
      padding-top: var(--nav-h);
    }
    .hero-text {
      position: relative; z-index: 2;
      text-align: center;
      display: flex; flex-direction: column; align-items: center; gap: 0;
    }
    .hero-catch {
      font-family: var(--font-jp); font-size: clamp(40px, 7vw, 80px);
      font-weight: 700; line-height: 1.14; letter-spacing: 0;
      color: var(--ink);
      min-height: 1.12em;
    }
    .hero-en {
      font-family: var(--font-en); font-size: clamp(12px, 1.2vw, 15px);
      font-weight: 600; letter-spacing: 0.1em;
      color: var(--ink-soft); margin-top: 22px;
      opacity: 0; transform: translateY(10px);
      transition: opacity 0.7s ease, transform 0.7s ease;
    }
    .hero-sub {
      font-family: var(--font-jp); font-size: clamp(13px, 1.4vw, 16px);
      font-weight: 400; color: var(--ink-mid);
      margin-top: 20px; max-width: 480px; line-height: 1.8;
      opacity: 0; transform: translateY(10px);
      transition: opacity 0.7s ease 0.15s, transform 0.7s ease 0.15s;
    }
    .hero-actions {
      display: flex; gap: 14px; margin-top: 40px;
      opacity: 0; transform: translateY(10px);
      transition: opacity 0.7s ease 0.3s, transform 0.7s ease 0.3s;
    }
    .hero-text.revealed .hero-en,
    .hero-text.revealed .hero-sub,
    .hero-text.revealed .hero-actions {
      opacity: 1; transform: none;
    }
    @keyframes dotBlink {
      0%, 100% { opacity: 1; }
      50% { opacity: 0; }
    }
    .services-grid {
      display: grid; grid-template-columns: repeat(4, 1fr);
      gap: 1px; background: var(--border);
      border: 1px solid var(--border); margin-top: 56px;
    }
    .service-card {
      background: var(--bg); padding: 36px 28px 32px;
      display: flex; flex-direction: column; gap: 14px;
      transition: background 0.2s; text-decoration: none; color: inherit;
    }
    .service-card:hover { background: var(--bg-alt); }
    .service-num {
      font-family: var(--font-en); font-size: 11px; font-weight: 500;
      color: var(--ink-soft); letter-spacing: 0.08em;
    }
    .service-arc { width: 40px; height: 40px; flex-shrink: 0; }
    .service-title { font-size: 15px; font-weight: 700; letter-spacing: 0; line-height: 1.45; }
    .service-title-en {
      font-family: var(--font-en); font-size: 11px; font-weight: 500;
      color: var(--ink-soft); letter-spacing: 0.04em;
    }
    .service-desc {
      font-size: 13px; font-weight: 400; color: var(--ink-mid);
      line-height: 1.75; margin-top: auto;
    }
    .service-card-cta {
      background: var(--ink);
      color: #fff;
      gap: 18px;
      padding-top: 40px;
      padding-bottom: 36px;
    }
    .service-card-cta:hover { background: #2a2a44; }
    .service-card-cta .service-num,
    .service-card-cta .service-desc {
      color: rgba(255, 255, 255, 0.6);
    }
    .service-card-cta .service-title { color: #fff; }
    .service-card-cta .service-desc { margin-top: 0; }
    .service-card-cta .service-cta-link {
      margin-top: auto;
      font-size: 13px; font-weight: 500; color: #fff;
      display: inline-flex; align-items: center; gap: 6px;
    }
    .service-card-cta .service-cta-arrow {
      font-family: var(--font-en);
      display: inline-block;
      transition: transform 0.2s ease;
    }
    .service-card-cta:hover .service-cta-arrow { transform: translateX(4px); }
    .approach-lead {
      font-size: 15px; font-weight: 400; color: var(--ink-mid);
      line-height: 1.9; max-width: 560px;
    }
    .approach-steps {
      display: grid; grid-template-columns: repeat(3, 1fr);
      gap: 1px; background: var(--border);
      border: 1px solid var(--border); margin-top: 56px;
    }
    .approach-step {
      background: var(--bg); padding: 32px 28px;
      display: flex; flex-direction: column; gap: 12px;
    }
    .approach-step-num {
      font-family: var(--font-en); font-size: 11px; font-weight: 500;
      color: var(--ink-soft); letter-spacing: 0.12em;
    }
    .approach-step-title { font-size: 17px; font-weight: 700; }
    .approach-step-body {
      font-size: 13px; font-weight: 400; color: var(--ink-mid); line-height: 1.8;
    }
    .approach-strengths-lead {
      margin-top: 64px; font-size: 16px; font-weight: 700; color: var(--ink);
    }
    .approach-strengths {
      display: grid; grid-template-columns: repeat(3, 1fr);
      gap: 40px; margin-top: 28px;
    }
    .approach-strength {
      border-top: 1px solid var(--border); padding-top: 20px;
      display: flex; flex-direction: column; gap: 10px;
    }
    .approach-strength-title { font-size: 14px; font-weight: 700; }
    .approach-strength-body {
      font-size: 13px; font-weight: 400; color: var(--ink-mid); line-height: 1.8;
    }
    .about-grid {
      display: grid; grid-template-columns: 1fr 1fr; gap: 80px;
      align-items: center; margin-top: 56px;
    }
    .about-text-block { display: flex; flex-direction: column; gap: 24px; }
    .about-body {
      font-size: 15px; font-weight: 400; color: var(--ink-mid);
      line-height: 1.9; max-width: 480px;
    }
    .about-img {
      display: block; width: 100%;
      aspect-ratio: 4/3;
      object-fit: cover;
      border: 1px solid var(--border);
    }
    @media (max-width: 900px) {
      .services-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 768px) {
      .hero-text { padding: 0 28px; width: 100%; }
      .catch-l1 { display: block; }
      .catch-l2 { display: block; text-align: right; }
      .services-grid { grid-template-columns: 1fr; }
      .approach-steps { grid-template-columns: 1fr; }
      .approach-strengths-lead { margin-top: 48px; }
      .approach-strengths { grid-template-columns: 1fr; }
      .about-grid { grid-template-columns: 1fr; gap: 40px; }
      .about-img { display: none; }
      .hero-actions { flex-direction: column; align-items: stretch; }
      .hero-actions .btn { justify-content: center; }
    }
    </style>
  </slot>

  <section class="hero">
    <div class="hero-text">
      <h1 class="hero-catch" aria-label="複雑をシンプルに"><span class="catch-l1" id="typeLine1">複雑を、</span><span class="catch-l2" id="typeLine2">シンプルに</span></h1>
      <p class="hero-en">Simplifying complexity.</p>
      <p class="hero-sub">システムも、AIも、Webも。<br>地域企業の「外部の情報システム部」として、ITのすべてに伴走します。</p>
      <div class="hero-actions">
        <a href="/contact" class="btn btn-primary btn-arrow">お問い合わせ</a>
        <a href="/services" class="btn btn-outline">事業内容を見る</a>
      </div>
    </div>
  </section>

  <section class="section" style="background: var(--bg);">
    <div class="section-inner">
      <p class="section-eyebrow">Services</p>
      <h2 class="section-title">事業内容</h2>
      <div class="services-grid">
        <a href="/services#dev" class="service-card">
          <span class="service-num">01</span>
          <svg class="service-arc" viewBox="0 0 40 40" fill="none">
            <circle cx="20" cy="20" r="17" stroke="#1a1a2e" stroke-width="1.5" stroke-linecap="round"
              stroke-dasharray="85 22" transform="rotate(-30 20 20)"/>
            <circle cx="20" cy="20" r="11" stroke="#1a1a2e" stroke-width="2" stroke-linecap="round"
              stroke-dasharray="55 15" transform="rotate(150 20 20)"/>
            <circle cx="20" cy="20" r="3.5" fill="#1a1a2e"/>
          </svg>
          <div>
            <div class="service-title">システム開発・DX支援</div>
            <div class="service-title-en">System Development &amp; DX</div>
          </div>
          <p class="service-desc">業務の整理からシステムの設計・実装・運用まで。複雑な業務をシンプルな仕組みへ。</p>
        </a>
        <a href="/services#ai" class="service-card">
          <span class="service-num">02</span>
          <svg class="service-arc" viewBox="0 0 40 40" fill="none">
            <circle cx="20" cy="20" r="17" stroke="#1a1a2e" stroke-width="1.2" stroke-linecap="round"
              stroke-dasharray="85 22" transform="rotate(-30 20 20)" opacity="0.35"/>
            <circle cx="20" cy="20" r="12" stroke="#1a1a2e" stroke-width="1.8" stroke-linecap="round"
              stroke-dasharray="60 16" transform="rotate(90 20 20)"/>
            <circle cx="20" cy="20" r="7" stroke="#1a1a2e" stroke-width="2.5" stroke-linecap="round"
              stroke-dasharray="35 9" transform="rotate(-150 20 20)"/>
            <circle cx="20" cy="20" r="2.5" fill="#1a1a2e"/>
          </svg>
          <div>
            <div class="service-title">AI導入・研修</div>
            <div class="service-title-en">AI Consulting &amp; Training</div>
          </div>
          <p class="service-desc">AIの導入支援から活用研修まで。業務に定着するAI活用を、両輪で支えます。</p>
        </a>
        <a href="/services#web" class="service-card">
          <span class="service-num">03</span>
          <svg class="service-arc" viewBox="0 0 40 40" fill="none">
            <circle cx="20" cy="20" r="17" stroke="#1a1a2e" stroke-width="1.5" stroke-linecap="round"
              stroke-dasharray="85 22" transform="rotate(-30 20 20)"/>
            <circle cx="20" cy="20" r="11" stroke="#1a1a2e" stroke-width="1.5" stroke-linecap="round"
              stroke-dasharray="55 14" transform="rotate(-30 20 20)" opacity="0.4"/>
            <circle cx="20" cy="20" r="4" fill="#1a1a2e" opacity="0.4"/>
            <circle cx="20" cy="20" r="2.5" fill="#1a1a2e"/>
          </svg>
          <div>
            <div class="service-title">Web制作</div>
            <div class="service-title-en">Web Production</div>
          </div>
          <p class="service-desc">企業サイト、LP、ブランドサイトの制作。目的に合ったデザインと実装を提供します。</p>
        </a>
        <a href="/contact" class="service-card service-card-cta">
          <span class="service-num">Contact</span>
          <div class="service-title">どれに当てはまるか、分からなくても。</div>
          <p class="service-desc">課題の整理からご一緒します。まずは現状をお聞かせください。</p>
          <span class="service-cta-link">相談する <span class="service-cta-arrow" aria-hidden="true">→</span></span>
        </a>
      </div>
    </div>
  </section>

  <section class="section" style="background: var(--bg-alt); border-top: 1px solid var(--border);">
    <div class="section-inner">
      <p class="section-eyebrow">Approach</p>
      <h2 class="section-title">いきなり、作らない。</h2>
      <p class="approach-lead">事業は3つ。進め方は、ひとつです。<br>複雑な課題をほどき、本当に必要なものを見極めてから、形にする。<br>vectonのすべての仕事は、この順番で進みます。</p>
      <div class="approach-steps">
        <div class="approach-step">
          <span class="approach-step-num">Step 01</span>
          <div class="approach-step-title">ほどく</div>
          <p class="approach-step-body">現状を聞き、課題を構造化します。要件が曖昧なままでも構いません。曖昧さを整理するのが最初の仕事です。</p>
        </div>
        <div class="approach-step">
          <span class="approach-step-num">Step 02</span>
          <div class="approach-step-title">見極める</div>
          <p class="approach-step-body">目的に照らして、やること・やらないことを決めます。技術やツールありきの提案はしません。</p>
        </div>
        <div class="approach-step">
          <span class="approach-step-num">Step 03</span>
          <div class="approach-step-title">形にする</div>
          <p class="approach-step-body">小さく作り、効果を確かめながら育てます。導入して終わりではなく、定着するまで伴走します。</p>
        </div>
      </div>
      <p class="approach-strengths-lead">めざすのは、地域企業の「外部の情報システム部」です。</p>
      <div class="approach-strengths">
        <div class="approach-strength">
          <div class="approach-strength-title">ITのことを、まとめて任せられる。</div>
          <p class="approach-strength-body">システムもAIもWebも、窓口はひとつ。専任の情シス部門がなくても、必要なときに必要な分だけ頼れます。</p>
        </div>
        <div class="approach-strength">
          <div class="approach-strength-title">プロジェクトで、終わらせない。</div>
          <p class="approach-strength-body">納品はゴールではありません。運用・改善・次の一手まで、社内のひとつの部門のように伴走し続けます。</p>
        </div>
        <div class="approach-strength">
          <div class="approach-strength-title">地域の実情から、考える。</div>
          <p class="approach-strength-body">岩手・盛岡から。地域企業の体制や予算感を踏まえ、身の丈に合った現実的な打ち手を提案します。</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section" style="background: var(--bg); border-top: 1px solid var(--border);">
    <div class="section-inner">
      <div class="about-grid">
        <div class="about-text-block">
          <p class="section-eyebrow">About</p>
          <h2 class="section-title">複雑な課題を、<br>シンプルに解く。</h2>
          <p class="about-body">vectonは、岩手・盛岡を拠点に、地域企業の「外部の情報システム部」として働くソフトウェア会社です。<br><br>専任のIT部門を持たない企業に代わって、業務の整理からシステム開発、AI活用、Webまでを引き受けます。複雑さに向き合い、シンプルに解く。それが私たちの仕事です。</p>
          <a href="/about" class="btn btn-outline btn-arrow">会社概要を見る</a>
        </div>
        <img class="about-img" src="/images/office-team-4x3.webp" alt="チームで課題を整理し協働する様子を表したイラスト" loading="lazy" width="800" height="600">
      </div>
    </div>
  </section>

  <Footer />

  <script>
    (function () {
      const el1 = document.getElementById('typeLine1') as HTMLElement | null;
      const el2 = document.getElementById('typeLine2') as HTMLElement | null;
      const heroText = document.querySelector('.hero-text') as HTMLElement | null;
      const charMs = 75;

      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        heroText?.classList.add('revealed');
        return;
      }

      const line1 = el1?.textContent ?? '';
      const line2 = el2?.textContent ?? '';
      if (el1) {
        el1.textContent = '';
        el1.setAttribute('aria-hidden', 'true');
      }
      if (el2) {
        el2.textContent = '';
        el2.setAttribute('aria-hidden', 'true');
      }

      function typeInto(el: HTMLElement | null, text: string, onDone?: () => void) {
        if (!el) {
          onDone?.();
          return;
        }
        let i = 0;
        function tick() {
          if (i < text.length) {
            const span = document.createElement('span');
            span.textContent = text[i];
            el!.appendChild(span);
            i++;
            setTimeout(tick, charMs);
          } else {
            onDone?.();
          }
        }
        tick();
      }

      function appendBlinkDot(el: HTMLElement | null) {
        if (!el) return;
        const dot = document.createElement('span');
        dot.style.cssText = [
          'display:inline-block',
          'width:0.18em',
          'height:0.18em',
          'background:currentColor',
          'vertical-align:baseline',
          'margin-left:0.12em',
          'animation:dotBlink 0.9s step-end infinite',
        ].join(';');
        el.appendChild(dot);
      }

      setTimeout(function () {
        typeInto(el1, line1, function () {
          setTimeout(function () {
            typeInto(el2, line2, function () {
              appendBlinkDot(el2);
              heroText?.classList.add('revealed');
            });
          }, 140);
        });
      }, 250);
    })();
  </script>
</Layout>
