---
import Layout from '../layouts/Layout.astro';
---
<Layout title="vecton — 複雑を、シンプルに。">
  <slot name="head" slot="head">
    <style>
    .hero {
      position: relative;
      height: 100svh; min-height: 600px;
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      overflow: hidden;
      padding-top: var(--nav-h);
    }
    .hero-text {
      position: relative; z-index: 2;
      text-align: center;
      display: flex; flex-direction: column; align-items: center; gap: 0;
    }
    .hero-catch {
      font-family: var(--font-jp); font-size: clamp(40px, 7vw, 80px);
      font-weight: 500; line-height: 1.12; letter-spacing: -0.025em;
      color: var(--ink);
      min-height: 1.12em;
    }
    .hero-en {
      font-family: var(--font-en); font-size: clamp(12px, 1.2vw, 15px);
      font-weight: 300; letter-spacing: 0.2em;
      color: var(--ink-soft); margin-top: 22px;
      opacity: 0; transform: translateY(10px);
      transition: opacity 0.7s ease, transform 0.7s ease;
    }
    .hero-sub {
      font-family: var(--font-jp); font-size: clamp(13px, 1.4vw, 16px);
      font-weight: 300; color: var(--ink-mid);
      margin-top: 20px; max-width: 480px; line-height: 1.8;
      opacity: 0; transform: translateY(10px);
      transition: opacity 0.7s ease 0.15s, transform 0.7s ease 0.15s;
    }
    .hero-actions {
      display: flex; gap: 14px; margin-top: 40px;
      opacity: 0; transform: translateY(10px);
      transition: opacity 0.7s ease 0.3s, transform 0.7s ease 0.3s;
    }
    .hero-text.revealed .hero-en,
    .hero-text.revealed .hero-sub,
    .hero-text.revealed .hero-actions {
      opacity: 1; transform: none;
    }
    @keyframes dotBlink {
      0%, 100% { opacity: 1; }
      50% { opacity: 0; }
    }
    .hero-scroll {
      position: absolute; bottom: 32px; left: 50%; transform: translateX(-50%);
      display: flex; flex-direction: column; align-items: center; gap: 8px;
      opacity: 0; animation: textIn 0.8s ease 1.8s forwards;
    }
    .hero-scroll span {
      font-family: var(--font-en); font-size: 10px; letter-spacing: 0.2em;
      color: var(--ink-soft); text-transform: uppercase;
    }
    .scroll-line {
      width: 1px; height: 40px;
      background: linear-gradient(to bottom, var(--ink-soft), transparent);
      animation: scrollPulse 2s ease-in-out 4s infinite;
    }
    @keyframes scrollPulse {
      0%,100% { opacity: 0.4; transform: scaleY(1); }
      50%      { opacity: 1;   transform: scaleY(1.2); }
    }
    .services-grid {
      display: grid; grid-template-columns: repeat(4, 1fr);
      gap: 1px; background: var(--border);
      border: 1px solid var(--border); margin-top: 56px;
    }
    .service-card {
      background: var(--bg); padding: 36px 28px 32px;
      display: flex; flex-direction: column; gap: 14px;
      transition: background 0.2s; text-decoration: none; color: inherit;
    }
    .service-card:hover { background: var(--bg-alt); }
    .service-num {
      font-family: var(--font-en); font-size: 11px; font-weight: 300;
      color: var(--ink-soft); letter-spacing: 0.1em;
    }
    .service-arc { width: 40px; height: 40px; flex-shrink: 0; }
    .service-title { font-size: 15px; font-weight: 500; letter-spacing: 0.01em; line-height: 1.4; }
    .service-title-en {
      font-family: var(--font-en); font-size: 11px; font-weight: 300;
      color: var(--ink-soft); letter-spacing: 0.06em;
    }
    .service-desc {
      font-size: 13px; font-weight: 300; color: var(--ink-mid);
      line-height: 1.75; margin-top: auto;
    }
    .about-grid {
      display: grid; grid-template-columns: 1fr 1fr; gap: 80px;
      align-items: center; margin-top: 56px;
    }
    .about-text-block { display: flex; flex-direction: column; gap: 24px; }
    .about-body {
      font-size: 15px; font-weight: 300; color: var(--ink-mid);
      line-height: 1.9; max-width: 480px;
    }
    .about-img {
      aspect-ratio: 4/3;
      background: repeating-linear-gradient(-45deg, var(--bg-alt) 0px, var(--bg-alt) 1px, transparent 1px, transparent 8px);
      border: 1px solid var(--border);
      display: flex; align-items: center; justify-content: center;
      color: var(--ink-soft); font-family: var(--font-en); font-size: 12px; letter-spacing: 0.1em;
    }
    @media (max-width: 900px) {
      .services-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 768px) {
      .hero-text { padding: 0 28px; width: 100%; }
      .catch-l1 { display: block; }
      .catch-l2 { display: block; text-align: right; }
      .services-grid { grid-template-columns: 1fr; }
      .about-grid { grid-template-columns: 1fr; gap: 40px; }
      .about-img { display: none; }
      .hero-actions { flex-direction: column; align-items: stretch; }
      .hero-actions .btn { justify-content: center; }
    }
    </style>
  </slot>

  <section class="hero">
    <div class="hero-text">
      <h1 class="hero-catch" aria-label="複雑を、シンプルに。"><span class="catch-l1" id="typeLine1"></span><span class="catch-l2" id="typeLine2"></span></h1>
      <p class="hero-en">Simplifying complexity.</p>
      <p class="hero-sub">業務フローのDX化、システム構築、AI導入まで。<br>ITの力で、ビジネスの課題を解決します。</p>
      <div class="hero-actions">
        <a href="/contact" class="btn btn-primary btn-arrow">お問い合わせ</a>
        <a href="/services" class="btn btn-outline">事業内容を見る</a>
      </div>
    </div>
    <div class="hero-scroll">
      <span>scroll</span>
      <div class="scroll-line"></div>
    </div>
  </section>

  <section class="section" style="background: var(--bg);">
    <div class="section-inner">
      <p class="section-eyebrow">Services</p>
      <h2 class="section-title">事業内容</h2>
      <div class="services-grid">
        <a href="/services#dx" class="service-card">
          <span class="service-num">01</span>
          <svg class="service-arc" viewBox="0 0 40 40" fill="none">
            <circle cx="20" cy="20" r="17" stroke="#1a1a2e" stroke-width="1.5" stroke-linecap="round"
              stroke-dasharray="85 22" transform="rotate(-30 20 20)" opacity="0.25"/>
            <path d="M20 20 L37 20 A17 17 0 1 0 20 3 Z" fill="#1a1a2e" opacity="0.12"/>
            <circle cx="20" cy="20" r="17" stroke="#1a1a2e" stroke-width="1.5" stroke-linecap="round"
              stroke-dasharray="85 22" transform="rotate(-30 20 20)"/>
            <circle cx="20" cy="20" r="5" fill="#1a1a2e"/>
          </svg>
          <div>
            <div class="service-title">DX推進・業務改善</div>
            <div class="service-title-en">Digital Transformation</div>
          </div>
          <p class="service-desc">業務フローの可視化から、システム刷新まで。複雑な業務を整理し、シンプルな仕組みへ。</p>
        </a>
        <a href="/services#dev" class="service-card">
          <span class="service-num">02</span>
          <svg class="service-arc" viewBox="0 0 40 40" fill="none">
            <circle cx="20" cy="20" r="17" stroke="#1a1a2e" stroke-width="1.5" stroke-linecap="round"
              stroke-dasharray="85 22" transform="rotate(-30 20 20)"/>
            <circle cx="20" cy="20" r="11" stroke="#1a1a2e" stroke-width="2" stroke-linecap="round"
              stroke-dasharray="55 15" transform="rotate(150 20 20)"/>
            <circle cx="20" cy="20" r="3.5" fill="#1a1a2e"/>
          </svg>
          <div>
            <div class="service-title">システム開発</div>
            <div class="service-title-en">System Development</div>
          </div>
          <p class="service-desc">受託・準委任での開発を行います。要件定義から設計・実装・運用まで一貫したサポート。</p>
        </a>
        <a href="/services#ai" class="service-card">
          <span class="service-num">03</span>
          <svg class="service-arc" viewBox="0 0 40 40" fill="none">
            <circle cx="20" cy="20" r="17" stroke="#1a1a2e" stroke-width="1.2" stroke-linecap="round"
              stroke-dasharray="85 22" transform="rotate(-30 20 20)" opacity="0.35"/>
            <circle cx="20" cy="20" r="12" stroke="#1a1a2e" stroke-width="1.8" stroke-linecap="round"
              stroke-dasharray="60 16" transform="rotate(90 20 20)"/>
            <circle cx="20" cy="20" r="7" stroke="#1a1a2e" stroke-width="2.5" stroke-linecap="round"
              stroke-dasharray="35 9" transform="rotate(-150 20 20)"/>
            <circle cx="20" cy="20" r="2.5" fill="#1a1a2e"/>
          </svg>
          <div>
            <div class="service-title">AI導入支援</div>
            <div class="service-title-en">AI Consulting</div>
          </div>
          <p class="service-desc">AIの活用可能性を探り、PoC設計から実装・定着まで。業務に馴染むAI導入を支援。</p>
        </a>
        <a href="/services#web" class="service-card">
          <span class="service-num">04</span>
          <svg class="service-arc" viewBox="0 0 40 40" fill="none">
            <circle cx="20" cy="20" r="17" stroke="#1a1a2e" stroke-width="1.5" stroke-linecap="round"
              stroke-dasharray="85 22" transform="rotate(-30 20 20)"/>
            <circle cx="20" cy="20" r="11" stroke="#1a1a2e" stroke-width="1.5" stroke-linecap="round"
              stroke-dasharray="55 14" transform="rotate(-30 20 20)" opacity="0.4"/>
            <circle cx="20" cy="20" r="4" fill="#1a1a2e" opacity="0.4"/>
            <circle cx="20" cy="20" r="2.5" fill="#1a1a2e"/>
          </svg>
          <div>
            <div class="service-title">Web制作</div>
            <div class="service-title-en">Web Production</div>
          </div>
          <p class="service-desc">企業サイト、LP、ブランドサイトの制作。目的に合ったデザインと実装を提供します。</p>
        </a>
      </div>
    </div>
  </section>

  <section class="section" style="background: var(--bg-alt); border-top: 1px solid var(--border);">
    <div class="section-inner">
      <div class="about-grid">
        <div class="about-text-block">
          <p class="section-eyebrow">About</p>
          <h2 class="section-title">複雑な課題を、<br>シンプルに解く。</h2>
          <p class="about-body">vectonは、ITを通じて企業のあらゆる課題をシンプルに解決するパートナーです。<br><br>業務の複雑さに向き合い、整理し、最適な技術を届けます。受託開発からAI活用まで、一貫した視点でサポートします。</p>
          <a href="/about" class="btn btn-outline btn-arrow">会社概要を見る</a>
        </div>
        <div class="about-img">office / team photo</div>
      </div>
    </div>
  </section>

  <div class="cta-band">
    <div class="cta-inner">
      <h2 class="cta-title">まずはお気軽にご相談ください。</h2>
      <p class="cta-sub">課題が明確でなくても構いません。現状をお聞かせいただくところから始めます。</p>
      <a href="/contact" class="btn-cta-white">お問い合わせ →</a>
    </div>
  </div>

  <script>
    (function () {
      const line1 = '複雑を';
      const line2 = 'シンプルに';
      const el1 = document.getElementById('typeLine1');
      const el2 = document.getElementById('typeLine2');
      const heroText = document.querySelector('.hero-text');
      const charMs = 75;

      function typeInto(el, text, onDone) {
        let i = 0;
        function tick() {
          if (i < text.length) {
            const span = document.createElement('span');
            span.textContent = text[i];
            el.appendChild(span);
            i++;
            setTimeout(tick, charMs);
          } else {
            onDone && onDone();
          }
        }
        tick();
      }

      function appendBlinkDot(el) {
        const dot = document.createElement('span');
        dot.style.cssText = [
          'display:inline-block',
          'width:0.18em',
          'height:0.18em',
          'background:currentColor',
          'vertical-align:baseline',
          'margin-left:0.12em',
          'animation:dotBlink 0.9s step-end infinite',
        ].join(';');
        el.appendChild(dot);
      }

      setTimeout(function () {
        typeInto(el1, line1, function () {
          setTimeout(function () {
            typeInto(el2, line2, function () {
              appendBlinkDot(el2);
              heroText.classList.add('revealed');
            });
          }, 140);
        });
      }, 250);
    })();
  </script>
</Layout>
