---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
---
<Layout
  title="事業内容 — vecton"
  activeNav="services"
  description="DX推進・業務改善、システム開発、AI導入支援、Web制作の4領域でお客様のビジネス課題を解決します。"
>
  <slot name="head" slot="head">
    <style>
    .service-block {
      display: grid; grid-template-columns: 1fr 1fr; gap: 80px;
      align-items: start; padding: 72px 0; border-top: 1px solid var(--border);
    }
    .service-block:first-child { border-top: none; padding-top: 0; }
    .service-block.reverse { direction: rtl; }
    .service-block.reverse > * { direction: ltr; }
    .svc-meta { display: flex; flex-direction: column; gap: 18px; }
    .svc-num {
      font-family: var(--font-en); font-size: 11px; font-weight: 500;
      color: var(--ink-soft); letter-spacing: 0.12em;
    }
    .svc-icon { width: 40px; height: 40px; flex-shrink: 0; margin-bottom: 4px; }
    .svc-title { font-size: clamp(22px, 3vw, 32px); font-weight: 700; line-height: 1.32; }
    .svc-title-en {
      font-family: var(--font-en); font-size: 13px; font-weight: 500;
      color: var(--ink-soft); letter-spacing: 0.06em; margin-top: -8px;
    }
    .svc-body {
      font-size: 14px; font-weight: 400; color: var(--ink-mid);
      line-height: 1.9; max-width: 440px;
    }
    .svc-tags { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 4px; }
    .svc-tag {
      font-family: var(--font-en); font-size: 11px; font-weight: 500;
      border: 1px solid var(--border); padding: 5px 12px;
      color: var(--ink-soft); letter-spacing: 0.04em;
    }
    .svc-visual {
      aspect-ratio: 4/3;
      background: repeating-linear-gradient(-45deg, var(--bg-alt) 0px, var(--bg-alt) 1px, transparent 1px, transparent 8px);
      border: 1px solid var(--border);
      display: flex; align-items: center; justify-content: center;
      color: var(--ink-soft); font-family: var(--font-en); font-size: 12px; font-weight: 500; letter-spacing: 0.08em;
    }
    .svc-flow { display: flex; flex-direction: column; gap: 0; border: 1px solid var(--border); }
    .flow-step {
      display: flex; align-items: flex-start; gap: 18px;
      padding: 18px 22px; border-bottom: 1px solid var(--border);
    }
    .flow-step:last-child { border-bottom: none; }
    .flow-n {
      font-family: var(--font-en); font-size: 11px; font-weight: 500;
      color: var(--ink-soft); letter-spacing: 0.08em; flex-shrink: 0; margin-top: 2px;
    }
    .flow-label { font-size: 13px; font-weight: 500; }
    .flow-desc { font-size: 12px; font-weight: 400; color: var(--ink-mid); line-height: 1.6; margin-top: 2px; }
    @media (max-width: 768px) {
      .service-block { grid-template-columns: 1fr; gap: 40px; padding: 48px 0; }
      .service-block.reverse { direction: ltr; }
    }
    </style>
  </slot>

  <div class="page-hero">
    <div class="page-hero-inner">
      <p class="page-hero-eyebrow">Services</p>
      <h1 class="page-hero-title">私たちにできること。</h1>
    </div>
  </div>

  <section class="section">
    <div class="section-inner">

      <div class="service-block" id="dx">
        <div class="svc-meta">
          <span class="svc-num">01</span>
          <svg class="svc-icon" viewBox="0 0 40 40" fill="none">
            <circle cx="20" cy="20" r="17" stroke="#1a1a2e" stroke-width="1.5" stroke-linecap="round"
              stroke-dasharray="85 22" transform="rotate(-30 20 20)" opacity="0.25"/>
            <path d="M20 20 L37 20 A17 17 0 1 0 20 3 Z" fill="#1a1a2e" opacity="0.12"/>
            <circle cx="20" cy="20" r="17" stroke="#1a1a2e" stroke-width="1.5" stroke-linecap="round"
              stroke-dasharray="85 22" transform="rotate(-30 20 20)"/>
            <circle cx="20" cy="20" r="5" fill="#1a1a2e"/>
          </svg>
          <h2 class="svc-title">DX推進・業務改善</h2>
          <p class="svc-title-en">Digital Transformation</p>
          <p class="svc-body">複雑化した業務フローを整理・可視化し、デジタル技術を活用したシンプルな仕組みへと刷新します。現場の実態に即した改善提案と、確実な実行をサポートします。</p>
          <div class="svc-tags">
            <span class="svc-tag">業務フロー可視化</span>
            <span class="svc-tag">システム刷新</span>
            <span class="svc-tag">RPA導入</span>
            <span class="svc-tag">内製化支援</span>
          </div>
        </div>
        <div class="svc-flow">
          <div class="flow-step">
            <span class="flow-n">Step 01</span>
            <div>
              <div class="flow-label">現状把握・ヒアリング</div>
              <div class="flow-desc">業務フロー・課題・目標の整理</div>
            </div>
          </div>
          <div class="flow-step">
            <span class="flow-n">Step 02</span>
            <div>
              <div class="flow-label">課題分析・改善提案</div>
              <div class="flow-desc">ボトルネック特定と解決策の策定</div>
            </div>
          </div>
          <div class="flow-step">
            <span class="flow-n">Step 03</span>
            <div>
              <div class="flow-label">システム設計・構築</div>
              <div class="flow-desc">要件定義から実装まで一貫対応</div>
            </div>
          </div>
          <div class="flow-step">
            <span class="flow-n">Step 04</span>
            <div>
              <div class="flow-label">定着支援・運用改善</div>
              <div class="flow-desc">導入後のフォローアップ</div>
            </div>
          </div>
        </div>
      </div>

      <div class="service-block reverse" id="dev">
        <div class="svc-meta">
          <span class="svc-num">02</span>
          <svg class="svc-icon" viewBox="0 0 40 40" fill="none">
            <circle cx="20" cy="20" r="17" stroke="#1a1a2e" stroke-width="1.5" stroke-linecap="round"
              stroke-dasharray="85 22" transform="rotate(-30 20 20)"/>
            <circle cx="20" cy="20" r="11" stroke="#1a1a2e" stroke-width="2" stroke-linecap="round"
              stroke-dasharray="55 15" transform="rotate(150 20 20)"/>
            <circle cx="20" cy="20" r="3.5" fill="#1a1a2e"/>
          </svg>
          <h2 class="svc-title">システム開発</h2>
          <p class="svc-title-en">System Development</p>
          <p class="svc-body">受託・準委任の形式で、業務システムやプロダクトの開発を行います。要件定義・設計・実装・テスト・運用まで、フルスタックで対応します。</p>
          <div class="svc-tags">
            <span class="svc-tag">受託開発</span>
            <span class="svc-tag">準委任</span>
            <span class="svc-tag">プロダクト開発</span>
            <span class="svc-tag">フルスタック</span>
          </div>
          <a href="/contact" class="btn btn-outline btn-arrow" style="margin-top:8px;">相談する</a>
        </div>
        <div class="svc-visual">system / product screenshot</div>
      </div>

      <div class="service-block" id="ai">
        <div class="svc-meta">
          <span class="svc-num">03</span>
          <svg class="svc-icon" viewBox="0 0 40 40" fill="none">
            <circle cx="20" cy="20" r="17" stroke="#1a1a2e" stroke-width="1.2" stroke-linecap="round"
              stroke-dasharray="85 22" transform="rotate(-30 20 20)" opacity="0.35"/>
            <circle cx="20" cy="20" r="12" stroke="#1a1a2e" stroke-width="1.8" stroke-linecap="round"
              stroke-dasharray="60 16" transform="rotate(90 20 20)"/>
            <circle cx="20" cy="20" r="7" stroke="#1a1a2e" stroke-width="2.5" stroke-linecap="round"
              stroke-dasharray="35 9" transform="rotate(-150 20 20)"/>
            <circle cx="20" cy="20" r="2.5" fill="#1a1a2e"/>
          </svg>
          <h2 class="svc-title">AI導入支援</h2>
          <p class="svc-title-en">AI Consulting &amp; Integration</p>
          <p class="svc-body">AIの活用可能性を整理し、PoC設計・実装・定着まで一貫して支援します。流行に流されず、業務に本当に馴染むAI活用を目指します。</p>
          <div class="svc-tags">
            <span class="svc-tag">AIコンサルティング</span>
            <span class="svc-tag">PoC設計</span>
            <span class="svc-tag">LLM活用</span>
            <span class="svc-tag">社内AI整備</span>
          </div>
        </div>
        <div class="svc-visual">AI workflow diagram</div>
      </div>

      <div class="service-block reverse" id="web">
        <div class="svc-meta">
          <span class="svc-num">04</span>
          <svg class="svc-icon" viewBox="0 0 40 40" fill="none">
            <circle cx="20" cy="20" r="17" stroke="#1a1a2e" stroke-width="1.5" stroke-linecap="round"
              stroke-dasharray="85 22" transform="rotate(-30 20 20)"/>
            <circle cx="20" cy="20" r="11" stroke="#1a1a2e" stroke-width="1.5" stroke-linecap="round"
              stroke-dasharray="55 14" transform="rotate(-30 20 20)" opacity="0.4"/>
            <circle cx="20" cy="20" r="4" fill="#1a1a2e" opacity="0.4"/>
            <circle cx="20" cy="20" r="2.5" fill="#1a1a2e"/>
          </svg>
          <h2 class="svc-title">Web制作</h2>
          <p class="svc-title-en">Web Production</p>
          <p class="svc-body">企業サイト、ランディングページ、ブランドサイトの制作。目的と対象ユーザーに合ったデザインと実装を提供します。</p>
          <div class="svc-tags">
            <span class="svc-tag">コーポレートサイト</span>
            <span class="svc-tag">LP制作</span>
            <span class="svc-tag">ブランドサイト</span>
            <span class="svc-tag">CMS構築</span>
          </div>
          <a href="/contact" class="btn btn-outline btn-arrow" style="margin-top:8px;">相談する</a>
        </div>
        <div class="svc-visual">website screenshot</div>
      </div>

    </div>
  </section>

  <Footer />
</Layout>
