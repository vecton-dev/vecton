---
import Layout from '../layouts/Layout.astro';
---
<Layout title="ページが見つかりません — vecton">
  <div class="page-hero">
    <div class="page-hero-inner">
      <p class="page-hero-eyebrow">404</p>
      <h1 class="page-hero-title">ページが見つかりません。</h1>
      <p style="margin-top: 24px; font-size: 14px; color: var(--ink-mid); line-height: 1.8; max-width: 480px;">
        お探しのページは移動または削除された可能性があります。
      </p>
      <p style="margin-top: 32px;">
        <a href="/" class="btn btn-outline btn-arrow">トップページへ戻る</a>
      </p>
    </div>
  </div>
</Layout>
