---
import Layout from '../layouts/Layout.astro';
---
<Layout title="お問い合わせ — vecton" activeNav="contact">
  <slot name="head" slot="head">
    <style>
    .contact-layout {
      display: grid; grid-template-columns: 1fr 1.4fr; gap: 80px;
      align-items: start; margin-top: 56px;
    }
    .contact-info {
      display: flex; flex-direction: column; gap: 36px;
      position: sticky; top: calc(var(--nav-h) + 40px);
    }
    .contact-copy {
      font-size: 14px; font-weight: 400; color: var(--ink-mid);
      line-height: 1.9; max-width: 360px;
    }
    .contact-detail-list { display: flex; flex-direction: column; gap: 0; }
    .contact-detail {
      display: flex; flex-direction: column; gap: 4px;
      padding: 18px 0; border-bottom: 1px solid var(--border);
    }
    .contact-detail:first-child { border-top: 1px solid var(--border); }
    .contact-detail-label {
      font-family: var(--font-en); font-size: 10px; font-weight: 500;
      color: var(--ink-soft); letter-spacing: 0.14em; text-transform: uppercase;
    }
    .contact-detail-value { font-size: 14px; font-weight: 400; color: var(--ink-mid); }
    .contact-form { display: flex; flex-direction: column; gap: 28px; }
    .form-group { display: flex; flex-direction: column; gap: 8px; }
    .form-label {
      font-size: 12px; font-weight: 500; color: var(--ink); letter-spacing: 0.01em;
      display: flex; align-items: center; gap: 8px;
    }
    .form-required {
      font-family: var(--font-en); font-size: 10px; font-weight: 500;
      color: var(--ink-soft); letter-spacing: 0.06em;
    }
    .form-input, .form-select, .form-textarea {
      width: 100%; background: var(--bg);
      border: 1px solid var(--border); border-radius: 0;
      padding: 13px 16px;
      font-family: var(--font-jp); font-size: 14px; font-weight: 400;
      color: var(--ink); outline: none;
      transition: border-color 0.2s;
      appearance: none; -webkit-appearance: none;
    }
    .form-input:focus, .form-select:focus, .form-textarea:focus { border-color: var(--ink); }
    .form-input::placeholder, .form-textarea::placeholder { color: var(--ink-soft); }
    .form-textarea { resize: vertical; min-height: 160px; line-height: 1.7; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
    .select-wrap { position: relative; }
    .select-wrap::after {
      content: ''; position: absolute; right: 16px; top: 50%;
      width: 8px; height: 8px;
      border-right: 1px solid var(--ink-soft); border-bottom: 1px solid var(--ink-soft);
      transform: translateY(-60%) rotate(45deg);
      pointer-events: none;
    }
    .form-submit { display: flex; flex-direction: column; gap: 14px; }
    .form-note { font-size: 12px; font-weight: 400; color: var(--ink-soft); line-height: 1.7; }
    .form-note a { color: var(--ink-mid); }
    .form-error {
      font-size: 13px; font-weight: 400; color: #b3261e; line-height: 1.6;
      display: none;
    }
    .form-error.visible { display: block; }
    .honeypot {
      position: absolute; left: -9999px; top: auto;
      width: 1px; height: 1px; overflow: hidden;
    }
    .btn-submit {
      background: var(--ink); color: #fff;
      border: none; cursor: pointer;
      padding: 16px 40px; font-family: var(--font-jp); font-size: 14px; font-weight: 500;
      letter-spacing: 0.04em;
      display: inline-flex; align-items: center; gap: 10px;
      transition: opacity 0.2s; align-self: flex-start;
    }
    .btn-submit:hover { opacity: 0.78; }
    .btn-submit::after { content: '→'; font-family: var(--font-en); font-weight: 400; }
    .form-success {
      display: none; flex-direction: column; align-items: center;
      text-align: center; gap: 20px; padding: 60px 40px;
      border: 1px solid var(--border);
    }
    .form-success.visible { display: flex; }
    .success-arc { animation: spinOnce 1s cubic-bezier(0.4,0,0.2,1) forwards; }
    @keyframes spinOnce {
      from { transform: rotate(-108deg); }
      to   { transform: rotate(252deg); }
    }
    .success-title { font-size: 20px; font-weight: 700; }
    .success-body { font-size: 14px; font-weight: 400; color: var(--ink-mid); line-height: 1.8; }
    @media (max-width: 768px) {
      .contact-layout { grid-template-columns: 1fr; gap: 48px; }
      .contact-info { position: static; }
      .form-row { grid-template-columns: 1fr; }
    }
    </style>
  </slot>

  <div class="page-hero">
    <div class="page-hero-inner">
      <p class="page-hero-eyebrow">Contact</p>
      <h1 class="page-hero-title">お気軽にご相談ください。</h1>
    </div>
  </div>

  <section class="section">
    <div class="section-inner">
      <div class="contact-layout">

        <div class="contact-info">
          <div>
            <p class="section-eyebrow">Get in touch</p>
            <p class="contact-copy">課題が明確でなくても構いません。まずは現状をお聞かせください。一緒に整理するところから始めます。</p>
          </div>
          <div class="contact-detail-list">
            <div class="contact-detail">
              <span class="contact-detail-label">Email</span>
              <span class="contact-detail-value">contact@vecton.dev</span>
            </div>
            <div class="contact-detail">
              <span class="contact-detail-label">Location</span>
              <span class="contact-detail-value">岩手県盛岡市</span>
            </div>
            <div class="contact-detail">
              <span class="contact-detail-label">Response</span>
              <span class="contact-detail-value">2営業日以内にご返信します</span>
            </div>
          </div>
        </div>

        <div>
          <form class="contact-form" id="contactForm" style="position:relative">

            <input class="honeypot" type="text" name="website" tabindex="-1" autocomplete="off" aria-hidden="true">

            <div class="form-row">
              <div class="form-group">
                <label class="form-label" for="name">
                  お名前 <span class="form-required">required</span>
                </label>
                <input class="form-input" type="text" id="name" name="name" autocomplete="name" placeholder="山田 太郎" required>
              </div>
              <div class="form-group">
                <label class="form-label" for="company">会社名</label>
                <input class="form-input" type="text" id="company" name="company" autocomplete="organization" placeholder="株式会社 ——">
              </div>
            </div>

            <div class="form-group">
              <label class="form-label" for="email">
                メールアドレス <span class="form-required">required</span>
              </label>
              <input class="form-input" type="email" id="email" name="email" autocomplete="email" placeholder="example@company.com" required>
            </div>

            <div class="form-group">
              <label class="form-label" for="type">お問い合わせ種別</label>
              <div class="select-wrap">
                <select class="form-select" id="type" name="type">
                  <option value="" disabled selected>選択してください</option>
                  <option value="dev">システム開発・DX支援</option>
                  <option value="ai">AI導入・研修</option>
                  <option value="web">Web制作</option>
                  <option value="other">その他</option>
                </select>
              </div>
            </div>

            <div class="form-group">
              <label class="form-label" for="message">
                お問い合わせ内容 <span class="form-required">required</span>
              </label>
              <textarea class="form-textarea" id="message" name="message"
                placeholder="現在の課題や、ご相談内容をお書きください。" required></textarea>
            </div>

            <div class="form-submit">
              <p class="form-note">
                送信いただいた内容は、<a href="/privacy">プライバシーポリシー</a>に基づき適切に管理します。
              </p>
              <p class="form-error" id="formError" role="alert"></p>
              <button type="submit" class="btn-submit">送信する</button>
            </div>

          </form>

          <div class="form-success" id="formSuccess">
            <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
              <circle class="success-arc" cx="24" cy="24" r="20"
                stroke="#1a1a2e" stroke-width="1.8" stroke-linecap="round"
                stroke-dasharray="94 32" transform="rotate(-108 24 24)"/>
            </svg>
            <p class="success-title">送信しました。</p>
            <p class="success-body">お問い合わせありがとうございます。<br>2営業日以内にご連絡いたします。</p>
            <a href="/" class="btn btn-outline">トップページへ戻る</a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <script>
  document.getElementById('contactForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const btn = form.querySelector('.btn-submit') as HTMLButtonElement | null;
    const errorEl = document.getElementById('formError') as HTMLElement | null;
    const originalLabel = btn?.textContent ?? '送信する';

    errorEl?.classList.remove('visible');
    if (errorEl) errorEl.textContent = '';

    if (btn) {
      btn.disabled = true;
      btn.textContent = '送信中…';
    }

    try {
      const data = Object.fromEntries(new FormData(form));
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      const result = (await res.json()) as { ok?: boolean; error?: string };

      if (res.ok && result.ok) {
        form.style.display = 'none';
        document.getElementById('formSuccess')?.classList.add('visible');
        return;
      }

      if (errorEl) {
        errorEl.textContent = result.error || '送信に失敗しました。時間をおいて再度お試しください。';
        errorEl.classList.add('visible');
      }
    } catch {
      if (errorEl) {
        errorEl.textContent = '送信に失敗しました。時間をおいて再度お試しください。';
        errorEl.classList.add('visible');
      }
    }

    if (btn) {
      btn.disabled = false;
      btn.textContent = originalLabel;
    }
  });
  </script>
</Layout>
